{
  "presets": [
    [
      "@babel/preset-env",
      {
        "targets": "> 0.5%, last 2 versions, Firefox ESR, not dead, not IE 11",
        "modules": false,
        "useBuiltIns": false,
        "debug": false
      }
    ]
  ],
  "plugins": [
    "@babel/plugin-transform-runtime"
  ],
  "ignore": [
    "node_modules/**",
    "dist/**"
  ]
}