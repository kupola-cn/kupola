{
  "Kupola: k-data scope": {
    "prefix": "k-data",
    "body": [
      "<div k-data=\"{ ${1:key}: ${2:value} }\">",
      "  $0",
      "</div>"
    ],
    "description": "Kupola data scope — creates a reactive data context"
  },
  "Kupola: k-text binding": {
    "prefix": "k-text",
    "body": "<${1:span} k-text=\"${2:expression}\"></${1:span}>",
    "description": "Kupola text binding — sets textContent from expression"
  },
  "Kupola: k-show directive": {
    "prefix": "k-show",
    "body": "<${1:div} k-show=\"${2:condition}\">$0</${1:div}>",
    "description": "Kupola show/hide — toggles display based on condition"
  },
  "Kupola: k-if directive": {
    "prefix": "k-if",
    "body": [
      "<${1:div} k-if=\"${2:condition}\">",
      "  $0",
      "</${1:div}>"
    ],
    "description": "Kupola conditional rendering"
  },
  "Kupola: k-if / k-else": {
    "prefix": "k-ifelse",
    "body": [
      "<${1:div} k-if=\"${2:condition}\">",
      "  ${3:<!-- true branch -->}",
      "</${1:div}>",
      "<${1:div} k-else>",
      "  ${4:<!-- false branch -->}",
      "</${1:div}>"
    ],
    "description": "Kupola if/else conditional rendering"
  },
  "Kupola: k-for loop": {
    "prefix": "k-for",
    "body": [
      "<template k-for=\"${1:item} in ${2:items}\" :key=\"${1:item}.${3:id}\">",
      "  <${4:div} k-text=\"${1:item}\"></${4:div}>",
      "</template>"
    ],
    "description": "Kupola list rendering with k-for"
  },
  "Kupola: k-for with index": {
    "prefix": "k-fori",
    "body": [
      "<template k-for=\"(${1:item}, ${2:index}) in ${3:items}\" :key=\"${1:item}.${4:id}\">",
      "  <${5:div}>",
      "    <span k-text=\"${2:index}\"></span>: <span k-text=\"${1:item}\"></span>",
      "  </${5:div}>",
      "</template>"
    ],
    "description": "Kupola list rendering with index"
  },
  "Kupola: k-bind attribute": {
    "prefix": "k-bind",
    "body": "k-bind:${1:class}=\"${2:expression}\"",
    "description": "Kupola attribute binding"
  },
  "Kupola: k-class": {
    "prefix": "k-class",
    "body": "k-class=\"{ '${1:is-active}': ${2:condition} }\"",
    "description": "Kupola conditional class binding"
  },
  "Kupola: k-ref": {
    "prefix": "k-ref",
    "body": "k-ref=\"${1:name}\"",
    "description": "Kupola scoped element reference"
  },
  "Kupola: k-init": {
    "prefix": "k-init",
    "body": "k-init=\"${1:init()}\"",
    "description": "Kupola one-time scope initialization"
  },
  "Kupola: k-transition": {
    "prefix": "k-transition",
    "body": [
      "<${1:div} k-show=\"${2:open}\" k-transition>",
      "  $0",
      "</${1:div}>",
      "",
      "<style>",
      ".kp-enter-active,",
      ".kp-leave-active {",
      "  transition: opacity 150ms ease;",
      "}",
      "",
      ".kp-enter-from,",
      ".kp-leave-to {",
      "  opacity: 0;",
      "}",
      "</style>"
    ],
    "description": "Kupola transition class lifecycle for k-show and k-if"
  },
  "Kupola: k-style": {
    "prefix": "k-style",
    "body": "k-style=\"{ ${1:color}: ${2:value} }\"",
    "description": "Kupola conditional style binding"
  },
  "Kupola: k-bind:disabled": {
    "prefix": "k-disabled",
    "body": "k-bind:disabled=\"${1:condition}\"",
    "description": "Kupola dynamic disabled binding"
  },
  "Kupola: k-on event": {
    "prefix": "k-on",
    "body": "k-on:${1:click}=\"${2:expression}\"",
    "description": "Kupola event handler"
  },
  "Kupola: k-on:click": {
    "prefix": "k-click",
    "body": "k-on:click=\"${1:expression}\"",
    "description": "Kupola click event handler"
  },
  "Kupola: k-on:submit": {
    "prefix": "k-submit",
    "body": "@submit.prevent=\"${1:save()}\"",
    "description": "Kupola form submit event handler with default submit prevented"
  },
  "Kupola: k-on:keydown": {
    "prefix": "k-keydown",
    "body": "k-on:keydown=\"${1:expression}\"",
    "description": "Kupola keydown event handler"
  },
  "Kupola: k-model input": {
    "prefix": "k-model",
    "body": "<input k-model=\"${1:variable}\" placeholder=\"${2:placeholder}\" />",
    "description": "Kupola two-way data binding on input"
  },
  "Kupola: k-model debounce": {
    "prefix": "k-model-debounce",
    "body": "<input k-model.trim.debounce.${1:300}=\"${2:keyword}\" placeholder=\"${3:Search}\" />",
    "description": "Kupola debounced two-way input binding"
  },
  "Kupola: k-model select": {
    "prefix": "k-model-select",
    "body": [
      "<select k-model=\"${1:variable}\">",
      "  <option value=\"${2:a}\">${3:Option A}</option>",
      "  <option value=\"${4:b}\">${5:Option B}</option>",
      "</select>"
    ],
    "description": "Kupola two-way data binding on select"
  },
  "Kupola: k-model checkbox": {
    "prefix": "k-model-check",
    "body": "<input type=\"checkbox\" k-model=\"${1:variable}\" />",
    "description": "Kupola two-way data binding on checkbox"
  },
  "Kupola: k-html directive": {
    "prefix": "k-html",
    "body": "<${1:div} k-html=\"${2:expression}\"></${1:div}>",
    "description": "Kupola HTML content binding (use with sanitized content only)"
  },
  "Kupola: k-cloak": {
    "prefix": "k-cloak",
    "body": "k-cloak",
    "description": "Kupola cloak — hides element until directives are initialized"
  },
  "Kupola: counter example": {
    "prefix": "kupola-counter",
    "body": [
      "<div k-data=\"{ count: 0 }\">",
      "  <p>Count: <strong k-text=\"count\"></strong></p>",
      "  <button k-on:click=\"count++\">+1</button>",
      "  <button k-on:click=\"count--\">-1</button>",
      "  <button k-on:click=\"count = 0\">Reset</button>",
      "</div>"
    ],
    "description": "Kupola counter example"
  },
  "Kupola: form example": {
    "prefix": "kupola-form",
    "body": [
      "<form k-data=\"{ name: '', email: '', role: 'user', saving: false }\" @submit.prevent=\"save()\">",
      "  <label>Name: <input k-model.trim=\"name\" /></label>",
      "  <label>Email: <input k-model.trim=\"email\" /></label>",
      "  <label>Role:",
      "    <select k-model=\"role\">",
      "      <option value=\"user\">User</option>",
      "      <option value=\"admin\">Admin</option>",
      "    </select>",
      "  </label>",
      "  <button :disabled=\"saving\">Save</button>",
      "  <pre k-text=\"JSON.stringify({name, email, role}, null, 2)\"></pre>",
      "</form>"
    ],
    "description": "Kupola form binding example"
  },
  "Kupola: theme toggle": {
    "prefix": "kupola-theme",
    "body": "<button k-on:click=\"document.documentElement.dataset.theme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark'\">Toggle Theme</button>",
    "description": "Kupola dark/light theme toggle"
  }
}
