{
  "name": "@kupola/core",
  "version": "3.1.1",
  "description": "Kupola core reactivity engine — Signal, computed, effect, batch.",
  "type": "module",
  "main": "dist/kupola-core.cjs",
  "module": "dist/kupola-core.esm.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/kupola-core.esm.js",
      "require": "./dist/kupola-core.cjs",
      "types": "./src/index.d.ts"
    },
    "./devtools": {
      "import": "./dist/kupola-core-devtools.esm.js",
      "require": "./dist/kupola-core-devtools.cjs"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "keywords": [
    "reactivity",
    "signal",
    "computed",
    "effect",
    "kupola"
  ],
  "author": "kupola-cn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kupola-cn/kupola",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/kupola-cn/kupola/issues"
  },
  "homepage": "https://kupola-cn.github.io/kupola/"
}
