{
  "name": "@kupola/core",
  "version": "3.0.0",
  "description": "Kupola core reactivity engine — Signal, computed, effect, batch, template, SSR, i18n.",
  "type": "module",
  "main": "dist/kupola-core.cjs",
  "module": "dist/kupola-core.esm.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/kupola-core.esm.js",
      "require": "./dist/kupola-core.cjs",
      "types": "./src/index.d.ts"
    },
    "./server": {
      "import": "./dist/kupola-core-server.esm.js",
      "require": "./dist/kupola-core-server.cjs",
      "types": "./src/server.d.ts"
    },
    "./directives": {
      "import": "./dist/kupola-core-directives.esm.js",
      "require": "./dist/kupola-core-directives.cjs",
      "types": "./src/directives.d.ts"
    },
    "./i18n": {
      "import": "./dist/kupola-core-i18n.esm.js",
      "require": "./dist/kupola-core-i18n.cjs",
      "types": "./src/i18n.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "keywords": [
    "reactivity",
    "signal",
    "computed",
    "effect",
    "kupola"
  ],
  "author": "kupola-cn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kupola-cn/kupola",
    "directory": "packages/core"
  }
}