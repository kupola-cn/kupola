    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "keywords": [
    "kupola",
    "ai",
    "natural-language",
    "command-engine",
    "query-engine",
    "workflow",
    "voice-control"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kupola-cn/kupola.git",
    "directory": "packages/ai-adapter"
  },
  "peerDependencies": {
    "@kupola/core": "^3.0.0"
  },
  "devDependencies": {
    "@kupola/core": "^3.0.0"
  },
  "scripts": {
    "test": "jest",
    "build": "rollup -c ../../rollup.config.cjs"
  }
