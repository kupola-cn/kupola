{
  "Kupola: import component": {
    "prefix": "kimport",
    "body": "import { ${1:ComponentName} } from '@kupola/components';",
    "description": "Import a Kupola component"
  },
  "Kupola: import multiple components": {
    "prefix": "kimports",
    "body": [
      "import {",
      "  ${1:Modal},",
      "  ${2:Button},",
      "  ${3:Table}",
      "} from '@kupola/components';"
    ],
    "description": "Import multiple Kupola components"
  },
  "Kupola: import core": {
    "prefix": "kimport-core",
    "body": "import { ${1:signal}, ${2:computed}, ${3:effect} } from '@kupola/core';",
    "description": "Import Kupola core reactivity primitives"
  },
  "Kupola: import walk (directives)": {
    "prefix": "kwalk",
    "body": [
      "import { walk } from '@kupola/core/directives';",
      "walk(document.body);"
    ],
    "description": "Import and initialize Kupola directive system"
  },
  "Kupola: signal": {
    "prefix": "ksignal",
    "body": "import { signal, computed, effect } from '@kupola/core';",
    "description": "Import Kupola reactivity primitives"
  },
  "Kupola: signal usage": {
    "prefix": "ksig",
    "body": [
      "const ${1:count} = signal(${2:0});",
      "effect(() => console.log(${1:count}.value));"
    ],
    "description": "Create a Kupola signal with effect"
  },
  "Kupola: reactive": {
    "prefix": "kreactive",
    "body": [
      "import { reactive, watch } from '@kupola/core';",
      "",
      "const ${1:state} = reactive({",
      "  ${2:name}: '${3:value}',",
      "});",
      "watch(() => ${1:state}.${2:name}, (val) => {",
      "  console.log(${2:name}, val);",
      "});"
    ],
    "description": "Create a reactive object with watch"
  },
  "Kupola: computed": {
    "prefix": "kcomputed",
    "body": "const ${1:name} = computed(() => ${2:expression});",
    "description": "Create a Kupola computed value"
  },
  "Kupola: effect": {
    "prefix": "keffect",
    "body": [
      "const dispose = effect(() => {",
      "  ${1:// side effect}",
      "});"
    ],
    "description": "Create a Kupola effect with dispose"
  },
  "Kupola: watch": {
    "prefix": "kwatch",
    "body": [
      "watch(() => ${1:source}, (val, oldVal) => {",
      "  ${2:// react to changes}",
      "});"
    ],
    "description": "Watch a reactive source for changes"
  },
  "Kupola: watch with options": {
    "prefix": "kwatchopt",
    "body": [
      "watch(() => ${1:source}, (val) => {",
      "  ${2:// callback}",
      "}, {",
      "  immediate: ${3:false},",
      "  deep: ${4:false},",
      "});"
    ],
    "description": "Watch with immediate and deep options"
  },
  "Kupola: provide": {
    "prefix": "kprovide",
    "body": [
      "import { provide } from '@kupola/core';",
      "",
      "provide('${1:key}', ${2:value});"
    ],
    "description": "Provide a value to child components"
  },
  "Kupola: inject": {
    "prefix": "kinject",
    "body": [
      "import { inject } from '@kupola/core';",
      "",
      "const ${1:value} = inject('${2:key}', ${3:defaultValue});"
    ],
    "description": "Inject a value from parent component"
  },
  "Kupola: i18n setup": {
    "prefix": "ki18n",
    "body": [
      "import { setLocale, t, formatDate, formatNumber } from '@kupola/core/i18n';",
      "",
      "setLocale('${1|en-US,zh-CN|}');"
    ],
    "description": "Set up Kupola i18n locale"
  },
  "Kupola: t function": {
    "prefix": "kt",
    "body": "t('${1:key}', ${2:{}})",
    "description": "Translate text using i18n"
  },
  "Kupola: formatDate": {
    "prefix": "kformatdate",
    "body": "formatDate(${1:new Date()}, '${2:short}')",
    "description": "Format date using i18n"
  },
  "Kupola: formatNumber": {
    "prefix": "kformatnum",
    "body": "formatNumber(${1:1234.56})",
    "description": "Format number using i18n"
  },
  "Kupola: lazyComponent": {
    "prefix": "klazy",
    "body": [
      "import { lazyComponent } from '@kupola/core';",
      "",
      "const ${1:Component} = lazyComponent(() => import('${2:./path}'));"
    ],
    "description": "Create a lazy-loaded component"
  },
  "Kupola: Modal usage": {
    "prefix": "kmodal",
    "body": [
      "import { Modal } from '@kupola/components';",
      "",
      "const modal = Modal({",
      "  title: '${1:Title}',",
      "  content: '${2:Content}',",
      "  onClose: () => {},",
      "});",
      "modal.open();"
    ],
    "description": "Create and open a Kupola Modal"
  },
  "Kupola: Dialog usage": {
    "prefix": "kdialog",
    "body": [
      "import { Dialog } from '@kupola/components';",
      "",
      "Dialog({",
      "  title: '${1:Confirm}',",
      "  content: '${2:Are you sure?}',",
      "  onConfirm: () => { ${3:// confirmed} },",
      "});"
    ],
    "description": "Create a Kupola confirmation dialog"
  },
  "Kupola: Table usage": {
    "prefix": "ktable",
    "body": [
      "import { Table } from '@kupola/components';",
      "",
      "Table({",
      "  columns: [",
      "    { key: '${1:id}', title: '${2:ID}' },",
      "    { key: '${3:name}', title: '${4:Name}' },",
      "  ],",
      "  data: ${5:[]},",
      "});"
    ],
    "description": "Create a Kupola data table"
  },
  "Kupola: Notification usage": {
    "prefix": "knotify",
    "body": [
      "import { Notification } from '@kupola/components';",
      "",
      "Notification({",
      "  title: '${1:Title}',",
      "  message: '${2:Message}',",
      "  type: '${3|success,error,warning,info|}',",
      "});"
    ],
    "description": "Show a Kupola notification"
  },
  "Kupola: ErrorBoundary": {
    "prefix": "kerror",
    "body": [
      "import { ErrorBoundary } from '@kupola/core';",
      "",
      "ErrorBoundary(() => ${1:componentFactory}(), {",
      "  fallback: '${2:Something went wrong}',",
      "  onError: (err) => console.error(err),",
      "});"
    ],
    "description": "Wrap component with ErrorBoundary"
  },
  "Kupola: renderToString (SSR)": {
    "prefix": "kssr",
    "body": [
      "import { renderToString } from '@kupola/core/server';",
      "",
      "const html = renderToString(${1:template});"
    ],
    "description": "Server-side render to string"
  },
  "Kupola: hydrate": {
    "prefix": "khydrate",
    "body": [
      "import { hydrate } from '@kupola/core';",
      "",
      "hydrate(${1:template}, ${2:container});"
    ],
    "description": "Hydrate server-rendered HTML"
  },
  "Kupola: theme setup": {
    "prefix": "ktheme",
    "body": [
      "import '@kupola/components/css/tokens.css';",
      "import '@kupola/components/css/components.css';",
      "import '@kupola/components/css/theme.css';"
    ],
    "description": "Import Kupola CSS design system"
  }
}