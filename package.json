{
  "name": "@kupola/kupola",
  "version": "1.5.0",
  "description": "A lightweight UI toolkit for any web project. No heavy frontend frameworks required.",
  "main": "dist/kupola.cjs.js",
  "module": "dist/kupola.esm.js",
  "types": "dist/types/kupola.d.ts",
  "type": "module",
  "sideEffects": [
    "./js/icons.js",
    "./js/theme-standalone.js",
    "*.css"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/kupola.esm.js",
      "require": "./dist/kupola.cjs.js",
      "types": "./dist/types/kupola.d.ts"
    },
    "./depends": {
      "import": "./js/depends.js",
      "types": "./dist/types/kupola.d.ts"
    },
    "./component": {
      "import": "./js/kupola-core.js"
    },
    "./data-bind": {
      "import": "./js/data-bind.js"
    },
    "./theme": {
      "import": "./js/theme.js"
    },
    "./icons": {
      "import": "./js/icons.js"
    },
    "./validation": {
      "import": "./js/validation.js"
    },
    "./vite": {
      "import": "./plugins/vite-plugin-kupola.js"
    },
    "./adapters/axios": {
      "import": "./adapters/axios.js",
      "types": "./adapters/axios.d.ts"
    },
    "./adapters/navios-http": {
      "import": "./adapters/navios-http.js",
      "types": "./adapters/navios-http.d.ts"
    },
    "./kupola.css": "./dist/css/kupola.css",
    "./kupola.min.css": "./dist/css/kupola.min.css",
    "./kupola.umd.js": "./dist/kupola.umd.js",
    "./kupola.min.js": "./dist/kupola.min.js",
    "./dist/css/kupola.css": "./dist/css/kupola.css",
    "./dist/css/*": "./dist/css/*",
    "./dist/icons/*": "./dist/icons/*",
    "./version.json": "./version.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:rollup": "rollup -c",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "build:css": "node scripts/build-css.cjs",
    "build:sprite": "node scripts/build-svg-sprite.cjs",
    "build:all": "node scripts/build-css.cjs && node scripts/build-svg-sprite.cjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "ui",
    "components",
    "design-system",
    "frontend",
    "vanilla-js",
    "no-framework",
    "lightweight",
    "ssr",
    "server-side-rendering",
    "declarative",
    "data-binding",
    "htmx-alternative",
    "alpinejs-alternative",
    "responsive",
    "dark-theme",
    "http-client",
    "axios-adapter",
    "typescript"
  ],
  "author": "kupola-cn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kupola-cn/kupola"
  },
  "bugs": {
    "url": "https://github.com/kupola-cn/kupola/issues"
  },
  "homepage": "https://github.com/kupola-cn/kupola",
  "files": [
    "dist/",
    "js/",
    "css/",
    "icons/",
    "plugins/",
    "adapters/",
    "types/",
    "scripts/",
    "version.json"
  ],
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "rollup": "^4.13.0",
    "rollup-plugin-copy": "^3.5.0",
    "vite": "^5.1.6"
  }
}
