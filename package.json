{
  "name": "@kupola/kupola",
  "version": "3.1.0",
  "description": "A zero-framework interaction layer and optional native component library for server-rendered HTML.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/platform",
    "packages/components",
    "packages/ai-adapter",
    "packages/create-kupola"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "clean": "node scripts/clean-build.mjs",
    "build": "npm run clean && rollup -c && npm run build:css",
    "build:rollup": "rollup -c",
    "build:css": "node scripts/build-css.cjs",
    "lint": "eslint .",
    "lint:core": "eslint packages/core/src packages/core/__tests__",
    "lint:platform": "eslint packages/platform/src packages/core/__tests__",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "jest --config jest.config.mjs",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "types:check": "tsc -p tsconfig.public-api.json",
    "package:smoke": "node scripts/package-smoke.mjs",
    "package:contents": "node scripts/package-contents-smoke.mjs",
    "release:metadata": "node scripts/release-metadata.mjs",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "verify": "npm run lint:platform && npm run release:metadata && npm run types:check && npm run test:coverage && npm run build && npm run package:smoke && npm run package:contents && npm run docs:build && npm run size",
    "release:check": "npm run verify",
    "release": "standard-version",
    "release:dry": "standard-version --dry-run",
    "release:major": "standard-version --release-as major",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:beta": "standard-version --prerelease beta",
    "release:rc": "standard-version --prerelease rc",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "keywords": [
    "ui",
    "components",
    "design-system",
    "frontend",
    "vanilla-js",
    "no-framework",
    "lightweight",
    "ssr",
    "server-side-rendering",
    "declarative",
    "data-binding",
    "htmx-alternative",
    "alpinejs-alternative",
    "responsive",
    "dark-theme",
    "typescript"
  ],
  "author": "kupola-cn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kupola-cn/kupola"
  },
  "bugs": {
    "url": "https://github.com/kupola-cn/kupola/issues"
  },
  "homepage": "https://kupola-cn.github.io/kupola/",
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/runtime": "^8.0.0",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/builder-vite": "^8.6.14",
    "@storybook/html": "^8.6.14",
    "@storybook/html-vite": "^8.6.14",
    "clean-css": "^5.3.3",
    "esbuild-jest": "^0.5.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "knip": "^6.26.0",
    "prettier": "^3.2.5",
    "rollup": "^4.13.0",
    "rollup-plugin-copy": "^3.5.0",
    "size-limit": "^12.1.0",
    "standard-version": "^9.5.0",
    "storybook": "^8.6.14",
    "vite": "^8.1.5",
    "vitepress": "^1.6.4"
  }
}
