    "@babel/preset-env": "^7.29.7",
    "@babel/runtime": "^8.0.0",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@size-limit/preset-app": "^12.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "knip": "^6.26.0",
    "prettier": "^3.2.5",
